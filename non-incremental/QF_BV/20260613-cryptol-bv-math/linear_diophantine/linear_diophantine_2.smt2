; Cryptol source code for this benchmark:
; // Soundness of a bounded linear-Diophantine solver.
; //
; // `solveLinearDiophantine a b c a_max b_max` returns `(found, x, y)` where
; // `found = True` implies `a*x - b*y == c` with `0 <= x <= a_max` and
; // `0 <= y <= b_max`.
; //
; // This benchmark asserts that *if* the inputs admit a witness `(x0, y0)`
; // with the stated bounds, the solver actually finds one. The encoded
; // problem is hard for two reasons:
; //
; //   1. The Bezout coefficients computed by the inner extended Euclidean
; //      algorithm grow unboundedly during iteration, so we run the body in
; //      a wider bitvector than the inputs.
; //
; //   2. Existence of a solution is intricate: it requires `gcd(a,b) | c`,
; //      and the constructed solution must satisfy two range constraints
; //      simultaneously, each involving the Bezout cofactors.
; //
; // Application: shows up in dependence analysis (loop nests), integer
; // programming, and stride-domain meets in abstract interpretation.
; //
; // Reference: classical number theory; the bounded variant is used in
; // abstract-domain algorithms.
; module linear_diophantine where
;
; type Property = Bit
;
; sQuot : {n} (fin n, n >= 1) => [n] -> [n] -> [n]
; sQuot x y = x /$ y
;
; sRem : {n} (fin n, n >= 1) => [n] -> [n] -> [n]
; sRem x y = x %$ y
;
; eGCD :
;   {n, steps} (fin n, fin steps, n >= 2) =>
;   [n] -> [n] -> ([n], [n], [n])
; eGCD a0 b0 =
;   if final.0 @ 0 then (- final.0, - final.1, - final.2)
;                  else final
;   where
;   step (a, b, x0, x1, y0, y1) =
;     if b == 0 then (a, 0, x0, x1, y0, y1)
;     else (b, sRem a b,
;           x1, x0 - sQuot a b * x1,
;           y1, y0 - sQuot a b * y1)
;   iters : [steps]([n], [n], [n], [n], [n], [n])
;   iters = take`{steps} (iterate step (a0, b0, 1, 0, 0, 1))
;   fs = iters ! 0
;   final = (fs.0, fs.2, fs.4)
;
; // floor / ceiling for signed division
; sFloorDiv : {n} (fin n, n >= 1) => [n] -> [n] -> [n]
; sFloorDiv x y =
;   if (x @ 0) ^ (y @ 0) /\ sRem x y != 0
;   then sQuot x y - 1
;   else sQuot x y
;
; sCeilDiv : {n} (fin n, n >= 1) => [n] -> [n] -> [n]
; sCeilDiv x y = - sFloorDiv (- x) y
;
; sMax : {n} (fin n, n >= 1) => [n] -> [n] -> [n]
; sMax x y = if x <$ y then y else x
;
; sMin : {n} (fin n, n >= 1) => [n] -> [n] -> [n]
; sMin x y = if x <$ y then x else y
;
; solveLinearDiophantine :
;   {n, steps} (fin n, fin steps, n >= 2) =>
;   [n] -> [n] -> [n] -> [n] -> [n] -> (Bit, [n], [n])
; solveLinearDiophantine a b c a_max b_max =
;   if cr != 0 then (False, 0, 0)
;   else if t <=$ t_upper then (True, n_co * cq + bq * t, m_co * cq + aq * t)
;   else (False, 0, 0)
;   where
;   egcd_res = eGCD`{n, steps} a (-b)
;   g    = egcd_res.0
;   n_co = egcd_res.1
;   m_co = egcd_res.2
;   cq   = sQuot c g
;   cr   = sRem c g
;   aq   = sQuot a g
;   bq   = sQuot b g
;   nc   = n_co * c
;   mc   = m_co * c
;   t       = sMax (sCeilDiv (-nc) b) (sCeilDiv (-mc) a)
;   t_upper = sMin (sFloorDiv (a_max * g - nc) b)
;                  (sFloorDiv (b_max * g - mc) a)
;
; // Sign-extend a `k`-bit value to `4*k` bits.
; sext4 : {k} (fin k, k >= 1) => [k] -> [4 * k]
; sext4 v = if v @ 0 then -1 # v else 0 # v
;
; // Soundness: if `(x0, y0)` is a witness within bounds for `c = a*x0 - b*y0`,
; // the solver returns a (possibly different) valid witness.
; solveLinearDiophantineSound :
;   {k} (fin k, k >= 1) =>
;   [k] -> [k] -> [k] -> [k] -> [k] -> [k] -> Property
; solveLinearDiophantineSound aBits bBits aMaxBits bMaxBits x0Bits y0Bits =
;   a >$ 0 ==> b >$ 0 ==> a_max >=$ 0 ==> b_max >=$ 0 ==>
;   0 <=$ x0 ==> x0 <=$ a_max ==>
;   0 <=$ y0 ==> y0 <=$ b_max ==>
;   c != 0 ==>
;     res.0 /\
;     (0 <=$ res.1 /\ res.1 <=$ a_max /\
;      0 <=$ res.2 /\ res.2 <=$ b_max /\
;      a * res.1 - b * res.2 == c)
;   where
;   a     = sext4 aBits
;   b     = sext4 bBits
;   a_max = sext4 aMaxBits
;   b_max = sext4 bMaxBits
;   x0    = sext4 x0Bits
;   y0    = sext4 y0Bits
;   c     = a * x0 - b * y0
;   res   = solveLinearDiophantine`{4*k, 4*k + 4} a b c a_max b_max
;
; property p2 = solveLinearDiophantineSound`{2}
; property p4 = solveLinearDiophantineSound`{4}
; property p8 = solveLinearDiophantineSound`{8}

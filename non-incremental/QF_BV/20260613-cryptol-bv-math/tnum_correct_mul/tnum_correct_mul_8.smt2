; Cryptol source code for this benchmark:
; // Tristate-number ("tnum") arithmetic, as used in the Linux kernel BPF
; // verifier and in abstract-domain implementations.
; //
; // A tnum (v, m) of width n represents the set
; //   { x : [n] | x .&. ~m == v .&. ~m }
; // i.e. the bits set in m are "unknown" and the others are pinned to the
; // corresponding bit of v. The disjointness invariant is v & m == 0.
; //
; // add: BPF verifier's bit-level add (Vishwanathan, Harishankar, Bhat,
; // Nagarakatte, "Sound, Precise, and Fast Abstract Interpretation with
; // Tristate Numbers", arXiv:2105.05398).
; //
; // mulPrecise: BPF verifier's tnum_mul, a shift-and-add over the bits of
; // the first operand. Quadratic in the bit width but strictly more
; // precise than the interval/trailing-zeros fast multiply.
; //
; // We benchmark correctness for each: if x is in tnum a and y is in tnum
; // b, then x+y (or x*y) is in tnum_add (or tnum_mulPrecise) of (a, b).
; module tnum where
;
; type Property = Bit
;
; // Disjointness invariant (smart-constructor precondition).
; proper : {n} (fin n) => [n] -> [n] -> Bit
; proper v m = v && m == 0
;
; // Membership: x is in the tnum (v, m) iff x and v agree on every fixed bit.
; member : {n} (fin n) => [n] -> [n] -> [n] -> Bit
; member v m x = (x && (~ m)) == (v && (~ m))
;
; // Tnum add: BPF verifier's bit-level addition.
; addTnum : {n} (fin n) => [n] -> [n] -> [n] -> [n] -> ([n], [n])
; addTnum av am bv bm = (resv, resm)
;   where
;   sm    = am + bm
;   sv    = av + bv
;   sigma = sm + sv
;   chi   = sigma ^ sv
;   resm  = chi || am || bm
;   resv  = sv && (~ resm)
;
; // Helpers for mulPrecise.
; foldl : {a, b, n} (fin n) => (a -> b -> a) -> a -> [n]b -> a
; foldl f z xs = (zs : [_]a) ! 0
;   where
;   zs = [z] # [ f y x | y <- zs | x <- xs ]
;
; // Tnum precise multiply: shift-and-add over the bits of `a` (BPF tnum_mul).
; mulPreciseTnum : {n} (fin n, n >= 1) => [n] -> [n] -> [n] -> [n] -> ([n], [n])
; mulPreciseTnum av am bv bm = foldl step init contribs
;   where
;   init = (av * bv, 0 : [n])
;   contribs = [ if av @ (`n - 1 - i)
;                  then (zero, bm << i)
;                  else if am @ (`n - 1 - i)
;                         then (zero, (bv || bm) << i)
;                         else (zero, zero)
;              | i <- [0 .. n-1] ]
;   step (v, m) (cv, cm) = addTnum v m cv cm
;
; // ---- correctness ----
;
; correct_add : {n} (fin n) => [n] -> [n] -> [n] -> [n] -> [n] -> [n] -> Property
; correct_add av am bv bm x y =
;   proper av am ==> proper bv bm ==>
;   member av am x ==> member bv bm y ==>
;   member resv resm (x + y)
;   where (resv, resm) = addTnum av am bv bm
;
; correct_mulPrecise : {n} (fin n, n >= 1) => [n] -> [n] -> [n] -> [n] -> [n] -> [n] -> Property
; correct_mulPrecise av am bv bm x y =
;   proper av am ==> proper bv bm ==>
;   member av am x ==> member bv bm y ==>
;   member resv resm (x * y)
;   where (resv, resm) = mulPreciseTnum av am bv bm
;
; property correct_add_4   = correct_add`{4}
; property correct_add_8   = correct_add`{8}
; property correct_add_16  = correct_add`{16}
; property correct_add_32  = correct_add`{32}
;
; property correct_mul_4   = correct_mulPrecise`{4}
; property correct_mul_8   = correct_mulPrecise`{8}
; property correct_mul_16  = correct_mulPrecise`{16}
; property correct_mul_32  = correct_mulPrecise`{32}

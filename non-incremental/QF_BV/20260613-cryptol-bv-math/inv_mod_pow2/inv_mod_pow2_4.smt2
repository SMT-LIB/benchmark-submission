; Cryptol source code for this benchmark:
; // Modular inverse modulo 2^n via Newton's iteration.
; //
; // For odd `a`, the recurrence  x_{i+1} = x_i * (2 - a * x_i)  doubles the
; // number of correct low bits at each step, so after `n` iterations starting
; // from `1` the result is `a^{-1} mod 2^n`. Equivalently, `a * invModPow2(a) ==
; // 1` in `n`-bit modular arithmetic.
; //
; // Property: for any odd `a`, `a * invModPow2(a) == 1`.
; //
; // Application: this trick is widely used in cryptographic primitives
; // (Montgomery reduction, hash-table sizing) and in compiler optimization
; // (replacing division-by-odd-constant with a multiplication).
; module inv_mod_pow2 where
;
; type Property = Bit
;
; invModPow2 : {n} (fin n, n >= 2) => [n] -> [n]
; invModPow2 a = (iterate step 1) @ `n
;   where step x = x * (2 - a * x)
;
; invModPow2Correct : {n} (fin n, n >= 2) => [n] -> Property
; invModPow2Correct a = isOdd ==> a * invModPow2 a == 1
;   where isOdd = a ! 0
;
; property p4  = invModPow2Correct`{4}
; property p8  = invModPow2Correct`{8}
; property p16 = invModPow2Correct`{16}
; property p32 = invModPow2Correct`{32}

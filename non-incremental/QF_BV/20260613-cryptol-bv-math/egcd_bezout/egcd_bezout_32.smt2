; Cryptol source code for this benchmark:
; // Extended Euclidean GCD as a QF_BV benchmark.
; //
; // `eGCD a b` returns `(g, x, y)` such that `x*a + y*b == g`. The classical
; // extended-Euclidean iteration, run in 2's-complement signed arithmetic on
; // a bitvector wide enough to hold all intermediate Bezout coefficients.
; //
; // The Bezout coefficients can be as large as `max(|a|, |b|)`, so we work
; // in `4*k` bits when the inputs are signed `k`-bit values. Iteration count
; // is set to `4*k + 4`, comfortably above the worst-case Fibonacci bound
; // (~1.44 * k).
; module egcd_bezout_bv where
;
; type Property = Bit
;
; // Signed quotient/remainder via Cryptol's signed division.
; sQuot : {n} (fin n, n >= 1) => [n] -> [n] -> [n]
; sQuot x y = x /$ y
;
; sRem : {n} (fin n, n >= 1) => [n] -> [n] -> [n]
; sRem x y = x %$ y
;
; eGCD :
;   {n, steps} (fin n, fin steps, n >= 2) =>
;   [n] -> [n] -> ([n], [n], [n])
; eGCD a0 b0 =
;   if final.0 @ 0  // top bit set => negative
;     then (- final.0, - final.1, - final.2)
;     else final
;   where
;   step (a, b, x0, x1, y0, y1) =
;     if b == 0 then (a, 0, x0, x1, y0, y1)
;     else (b, sRem a b,
;           x1, x0 - sQuot a b * x1,
;           y1, y0 - sQuot a b * y1)
;   iters : [steps]([n], [n], [n], [n], [n], [n])
;   iters = take`{steps} (iterate step (a0, b0, 1, 0, 0, 1))
;   finalState = iters ! 0
;   final = (finalState.0, finalState.2, finalState.4)
;
; // Sign-extend a `k`-bit signed value to `4*k` bits.
; sext4 : {k} (fin k, k >= 1) => [k] -> [4 * k]
; sext4 v = signExtend v
;   where
;   signExtend : [k] -> [4 * k]
;   signExtend x = if x @ 0 then -1 # x else 0 # x
;
; eGCD_bezout : {k} (fin k, k >= 1, 4 * k >= 2) => [k] -> [k] -> Property
; eGCD_bezout aBits bBits =
;   egcd_res.1 * a + egcd_res.2 * b == egcd_res.0
;   where
;   a = sext4 aBits
;   b = sext4 bBits
;   egcd_res = eGCD`{4 * k, 4 * k + 4} a b
;
; property p4  = eGCD_bezout`{4}
; property p8  = eGCD_bezout`{8}
; property p16 = eGCD_bezout`{16}
; property p32 = eGCD_bezout`{32}

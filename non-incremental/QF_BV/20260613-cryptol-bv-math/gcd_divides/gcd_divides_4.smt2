; Cryptol source code for this benchmark:
; // Soundness of an unsigned binary-style GCD: the result divides both inputs.
; //
; // `gcd a b` runs a fixed number of "subtract the smaller from the larger"
; // iterations of Euclid's algorithm in `n`-bit unsigned arithmetic. The
; // number of iterations is set to `2*n + 2`, well above the Fibonacci bound
; // for `n`-bit inputs.
; //
; // Property: `g` divides `a` and `g` divides `b`, where `g = gcd a b`.
; //
; // (Modular wraparound makes "divides" subtle in fixed-width arithmetic; we
; // state divisibility via `a % g == 0`.)
; //
; // Application: building block in number-theoretic abstract domains and in
; // constraint solvers that reason about strides/congruences.
; module gcd_divides where
;
; type Property = Bit
;
; gcd : {n, steps} (fin n, fin steps, n >= 1) => [n] -> [n] -> [n]
; gcd a0 b0 = (iters ! 0).0
;   where
;   step (a, b) =
;     if b == 0 then (a, 0)
;     else (b, a % b)
;   iters : [steps]([n], [n])
;   iters = take`{steps} (iterate step (a0, b0))
;
; gcdDividesBoth : {n} (fin n, n >= 2) => [n] -> [n] -> Property
; gcdDividesBoth a b =
;   a > 0 ==> b > 0 ==> g > 0 /\ a % g == 0 /\ b % g == 0
;   where g = gcd`{n, 2*n + 2} a b
;
; property p4  = gcdDividesBoth`{4}
; property p8  = gcdDividesBoth`{8}
; property p16 = gcdDividesBoth`{16}
; property p32 = gcdDividesBoth`{32}

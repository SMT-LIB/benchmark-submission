; module gcd_divides where
;
; type Property = Bit
;
; gcd : {n, steps} (fin n, fin steps, n >= 1) => [n] -> [n] -> [n]
; gcd a0 b0 = (iters ! 0).0
;   where
;   step (a, b) =
;     if b == 0 then (a, 0)
;     else (b, a % b)
;   iters : [steps]([n], [n])
;   iters = take`{steps} (iterate step (a0, b0))
;
; gcdDividesBoth : {n} (fin n, n >= 2) => [n] -> [n] -> Property
; gcdDividesBoth a b =

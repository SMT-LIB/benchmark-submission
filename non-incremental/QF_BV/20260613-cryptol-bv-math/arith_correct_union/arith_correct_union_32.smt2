; Cryptol source code for this benchmark:
; // Correctness of `union` on the arithmetic interval abstract domain,
; // as used in What4 (and many other software-engineering applications:
; // range analysis in compilers, polyhedral analysis, etc.).
; //
; // A `Dom n` is either an empty domain (the `isBot` flag) or an
; // "interval" {lo, sz} representing the wraparound-aware set
; //
; //   { x : [n] | x - lo <= sz }
; //
; // (where the subtraction wraps modulo 2^n). This lets one element
; // describe both ordinary intervals like [3, 9] and wraparound intervals
; // like [0xFC, 0x07] in 8 bits.
; //
; // `union` chooses representatives of the two interval midpoints whose
; // difference fits within 2^(n-1), then takes the bounding interval over
; // the resulting endpoints. The construction is subtle because of the
; // wraparound-aware arithmetic.
; //
; // Property: correct_union -- for any x in either input, x is in the
; // union (soundness of the abstract join).
; module arith_union where
;
; type Property = Bit
;
; type Dom n = { lo : [n], sz : [n], isBot : Bit }
;
; interval : {n} (fin n) => [n] -> [n] -> Dom n
; interval l s = { lo = l, sz = s, isBot = False }
;
; bottom : {n} (fin n) => Dom n
; bottom = { lo = 0, sz = 0, isBot = True }
;
; bit : {i, n} (fin n, n > i) => [n]
; bit = 1 # (0 : [i])
;
; top : {n} (fin n) => Dom n
; top = interval 0 (~ 0)
;
; mem : {n} (fin n) => Dom n -> [n] -> Bit
; mem a x = ~ a.isBot /\ x - a.lo <= a.sz
;
; /** Carry detection on unsigned add. Used to check overflow within
;     `union` (both inputs zero-extended to `[n+2]` so they don't really
;     overflow there; the helper still preserves intent). */
; carry : {n} (fin n) => [n] -> [n] -> Bit
; carry x y = (x + y) < x
;
; /** Checked unsigned addition (no overflow expected by construction). */
; infixl 80 .+.
; (.+.) : {n} (fin n) => [n] -> [n] -> [n]
; x .+. y = if carry x y then error "overflow" else x + y
;
; /** Checked unsigned subtraction. */
; infixl 80 .-.
; (.-.) : {n} (fin n) => [n] -> [n] -> [n]
; x .-. y = if x < y then error "underflow" else x - y
;
; /** Lattice join / set union over the wraparound-aware arithmetic
;     interval domain.
;
;     Picks endpoint representatives in `[n+2]` so the midpoints of the
;     two intervals are within 2^(n-1) of each other, then takes the
;     bounding interval of the four endpoints. If the spanning width
;     reaches 2^n, the result is top. */
; union : {n} (fin n) => Dom n -> Dom n -> Dom n
; union a b =
;   if a.isBot /\ b.isBot then bottom
;   else if a.isBot then b
;   else if b.isBot then a
;   else if cw >= size then top
;   else interval (drop`{2} cl) (drop`{2} cw)
;   where
;     size : [n+2]
;     size = bit`{n}
;     am = 2 * zext a.lo .+. zext a.sz
;     bm = 2 * zext b.lo .+. zext b.sz
;     al' = if am .+. size < bm then zext a.lo .+. size else zext a.lo
;     bl' = if bm .+. size < am then zext b.lo .+. size else zext b.lo
;     ah' = al' .+. zext a.sz
;     bh' = bl' .+. zext b.sz
;     cl = min al' bl'
;     ch = max ah' bh'
;     cw = ch .-. cl
;
;
; // -------- properties --------
;
; correct_union : {n} (fin n) => Dom n -> Dom n -> [n] -> Property
; correct_union a b x =
;   (mem a x \/ mem b x) ==> mem (union a b) x
;
; property correct_union_4   = correct_union`{4}
; property correct_union_8   = correct_union`{8}
; property correct_union_16  = correct_union`{16}
; property correct_union_32  = correct_union`{32}

(declare-fun keep (Node) Bool)
(declare-fun kept_edge (Node Node) Bool)
(declare-fun color (Node) Color)

(assert (forall ((x Node) (y Node))
                (or (keep x) (keep y) (= x y))))
(assert (forall ((x Node) (y Node))
                (= (kept_edge x y)
                   (and (keep x) (keep y) (edge x y)))))
(assert (forall ((x Node) (y Node))
                (=> (kept_edge x y)
                    (not (= (color x) (color y))))))
(assert (forall ((x Node))
                (=> (not (keep x))
                    (= (color x) red))))

(check-sat)
(exit)
